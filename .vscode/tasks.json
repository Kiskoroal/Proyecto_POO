{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar Proyecto Completo (g++)",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${fileDirname}/*.cpp", // Compila todos los .cpp de la carpeta
                "-o",
                "${fileDirname}/main_app" // Nombre del ejecutable fijo
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compila todos los .cpp en la carpeta actual usando Arch Linux."
        }
    ]
}